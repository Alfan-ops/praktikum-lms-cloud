# Template environment variables.
# Salin file ini menjadi `.env` lalu isi nilai aslinya.
# JANGAN commit file `.env` yang sudah berisi kunci asli.

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi_dengan_service_role_key_anda

# --- Flask (Backend Manajemen) ---
FLASK_APP=management.py
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5001
FLASK_DEBUG=True

# --- Orchestrator ---
ORCHESTRATOR_URL=http://orchestrator:4000
