  "title": "LMS Praktikum - Monitoring Per-Container",
  "uid": "lms-containers",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "title": "Jumlah Container Praktikum Hidup",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_total",
          "legendFormat": "Container hidup",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total CPU Semua Container (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(lms_container_cpu_percent)",
          "legendFormat": "Total CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Memori Semua Container",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2147483648 },
              { "color": "red", "value": 6442450944 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(lms_container_memory_bytes)",
          "legendFormat": "Total Memori",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU per Container (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_cpu_percent",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memori per Container",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_memory_bytes",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pemakaian Memori vs Limit (%)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_memory_bytes / lms_container_memory_limit_bytes * 100",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Tabel Stats Per-Container (Saat Ini)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU (%)" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byName", "options": "Memori" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "fields": "" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_cpu_percent",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "lms_container_memory_bytes",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "container",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "job": true,
              "job 1": true,
              "job 2": true
            },
            "indexByName": {
              "container": 0,
              "Value #A": 1,
              "Value #B": 2
            },
            "renameByName": {
              "container": "Container",
              "Value #A": "CPU (%)",
              "Value #B": "Memori"
            }
          }
        }
      ]
    }
  ]
}
